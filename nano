generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Monitoramento {
  id           Int      @id @default(autoincrement())
  dispositivo  String
  temperatura  Float
  umidade      Float
  status       String
  pesoKg       Float?
  litros       Float?
  createdAt    DateTime @default(now())
}
